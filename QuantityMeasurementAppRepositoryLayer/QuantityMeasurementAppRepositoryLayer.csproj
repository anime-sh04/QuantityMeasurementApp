    <TargetFramework>net10.0</TargetFramework>
    <LangVersion>latest</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <AssemblyName>QuantityMeasurementAppRepositoryLayer</AssemblyName>
    <RootNamespace>QuantityMeasurementAppRepositoryLayer</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
